# Oura API token (https://cloud.ouraring.com/personal-access-tokens)
OURA_TOKEN=your_oura_personal_access_token

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_secret_key_here

# Dashboard login password (store a hashed value, not plaintext)
# Generate with: python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your_password'))"
APP_PASSWORD=scrypt:32768:8:1$...
